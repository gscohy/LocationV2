# Copier ce fichier en `.env` (dans ce dossier) et remplir.
# Le `.env` est gitignored : il ne sera jamais commit.

# ----- Base locale (DBeaver) -----
# Format URI postgres
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
LOCAL_DB_URL=postgresql://postgres:motdepasse@localhost:5432/loc_local

# ----- Supabase cible -----
SUPABASE_URL=https://yrlczclebqycmyazsjzj.supabase.co

# Service role key — donne tous les droits, à révoquer après migration.
# À trouver dans : Supabase Dashboard → Project Settings → API Keys → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# UUID du user Supabase qui sera "propriétaire" des données importées
# (= colonne owner_user_id sur proprietaires, charges, etc.)
# À trouver dans : Supabase Dashboard → Authentication → Users → ton compte → UID
SUPABASE_OWNER_USER_ID=00000000-0000-0000-0000-000000000000
