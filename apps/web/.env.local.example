# Copier ce fichier en .env.local et remplir avec les vraies valeurs.
# .env.local est gitignore (jamais commit).

# Supabase cloud : Settings > API Keys (publishable key + project URL)
# Pour le dev local via Supabase CLI : http://localhost:54321 + clé du seed
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx
